function parse_git_branch {
  	git branch --no-color 2> /dev/null |  grep '^*' | colrm 1 2
}

function set_upstream {
    if ! git rev-parse --abbrev-ref --symbolic-full-name @{u} > /dev/null 2>&1; then
        git branch --set-upstream-to="origin/${1:?}"
    fi
}

function unpushed_changes {
    git rev-list --count @{u}..HEAD 2>/dev/null || echo "0"
}

function check_if_in_repo {
	git status 2> /dev/null
}

function check_uncommitted_changes {
	git status -s 2> /dev/null
}

TEXT_RED_COLOR_PS="\033[0;31m"
TEXT_YELLOW_COLOR_PS="\033[0;33m"
TEXT_GREEN_COLOR_PS="\033[0;32m"
TEXT_END_OF_COLOR_PS="\033[0m"
UNCOMMITTED_ERROR_PS="[ x ]"
UNPUSHED_WARNING_PS="[ ! ]"
ALL_CLEAN_PS="[ ✔ ]"
GIT_LOGO_PS=""

function set_custom_ps {
    if  [[ "$(check_if_in_repo)" ]]; then
        set_upstream "$(parse_git_branch)"
	    if expr length + "$(check_uncommitted_changes)" 2>&1 > /dev/null; then     
	        echo -ne "${TEXT_RED_COLOR_PS}${UNCOMMITTED_ERROR_PS}${TEXT_END_OF_COLOR_PS}"; 
	    else
	    	if [ $(unpushed_changes) -gt 0 ]; then
	            echo -ne "${TEXT_YELLOW_COLOR_PS}${UNPUSHED_WARNING_PS}${TEXT_END_OF_COLOR_PS}"; 
			else
	            echo -ne "${TEXT_GREEN_COLOR_PS}${ALL_CLEAN_PS}${TEXT_END_OF_COLOR_PS}"; 
			fi
	    fi
    fi
}

function set_branch_name {
    if  [[ "$(check_if_in_repo)" ]]; then
        echo -ne "(${GIT_LOGO_PS} $(parse_git_branch))";
    fi
}
